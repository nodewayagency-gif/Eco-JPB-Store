generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  OPERATOR
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum SessionScope {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  CREATED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentGatewayProvider {
  MERCADO_PAGO
  ASAAS
}

enum ShippingProvider {
  MERCADO_LIVRE
  MELHOR_ENVIO
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  role            Role             @default(CUSTOMER)
  status          UserStatus       @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  adminProfile    AdminProfile?
  customerProfile CustomerProfile?
  accounts        Account[]
  sessions        Session[]
  orders          Order[]
  reviews         Review[]
  cart            Cart?
  tickets         SupportTicket[]

  @@map("jpb_users")
}

model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  permissions String[] @default([])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("jpb_admin_profiles")
}

model CustomerProfile {
  id             String            @id @default(cuid())
  userId         String            @unique
  name           String
  phone          String?
  document       String?           @unique // CPF ou CNPJ
  documentType   String?           // "CPF" ou "CNPJ"
  defaultAddress String?
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses      CustomerAddress[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("jpb_customer_profiles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("jpb_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("jpb_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("jpb_verification_tokens")
}

model Product {
  id                  String    @id @default(cuid())
  slug                String?   @unique
  sku                 String    @unique
  name                String
  categoryId          String?
  category            Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description         String
  price               Decimal   @db.Decimal(12, 2)
  originalPrice       Decimal?  @db.Decimal(12, 2)
  image               String
  images              String[]  @default([])
  badge               String?
  inStock             Boolean   @default(true)
  stockQuantity       Int       @default(0)
  minStockAlert       Int       @default(5)
  active              Boolean   @default(true)
  rating              Float     @default(0)
  reviewCount         Int       @default(0)
  costPrice           Decimal   @db.Decimal(12, 2)
  ncm                 String?
  ean                 String?
  taxPercent          Decimal?  @db.Decimal(5, 2)
  gatewayProductId    String?
  melhorEnvioCategory String?
  weightKg            Decimal   @db.Decimal(8, 3)
  lengthCm            Decimal   @db.Decimal(8, 2)
  widthCm             Decimal   @db.Decimal(8, 2)
  heightCm            Decimal   @db.Decimal(8, 2)
  originZipCode       String
  freeShipping        Boolean   @default(false)
  fragile             Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orderItems OrderItem[]
  variants   ProductVariant[]
  reviews    Review[]
  cartItems  CartItem[]

  @@index([categoryId])
  @@index([active])
  @@map("jpb_products")
}

model Order {
  id                   String      @id @default(cuid())
  orderCode            String      @unique
  customerId           String?
  guestName            String?
  guestEmail           String?
  guestPhone           String?
  guestDocument        String?
  status               OrderStatus @default(CREATED)
  total                Decimal     @db.Decimal(12, 2)
  paymentStatus        String?
  paymentGateway       String?
  gatewayTransactionId String?
  shippingCarrier      String?
  shippingQuoteId      String?
  shippingCost         Decimal?    @db.Decimal(12, 2)
  shippingAddress      Json?       // Endereço completo de entrega
  paymentMethodId      String?     // Ex: "visa", "master", "pix"
  installments         Int?        @default(1)
  gatewayResponse      Json?       // Resposta bruta do gateway para auditoria
  channel              String      @default("Loja Virtual") // "Loja Virtual" ou "Venda externa"
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  customer             User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items                OrderItem[]
  steps                OrderStep[]

  @@index([customerId, status])
  @@index([status])
  @@index([createdAt])
  @@map("jpb_orders")
}

model OrderStep {
  id        String   @id @default(cuid())
  orderId   String
  key       String   // "created", "payment_confirmed", "in_separation", etc.
  label     String
  completed Boolean  @default(false)
  active    Boolean  @default(false)
  source    String   @default("system") // "system" ou "manual"
  updatedAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("jpb_order_steps")
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  quantity  Int             @default(1)
  unitPrice Decimal         @db.Decimal(12, 2)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("jpb_order_items")
}

model CompanyConfig {
  id            String   @id @default(cuid())
  companyName   String
  tradeName     String?
  document      String
  email         String
  phone         String
  originZipCode String
  addressLine   String
  city          String
  state         String
  instagramUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("jpb_company_config")
}

model PaymentGatewayConfig {
  id            String                 @id @default(cuid())
  provider      PaymentGatewayProvider
  enabled       Boolean                @default(false)
  publicKey     String?
  accessToken   String?
  apiKey        String?
  walletId      String?
  webhookSecret String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([provider])
  @@map("jpb_payment_gateway_config")
}

model ShippingIntegrationConfig {
  id           String           @id @default(cuid())
  provider     ShippingProvider
  enabled      Boolean          @default(false)
  appId        String?
  clientId     String?
  clientSecret String?
  accessToken  String?
  tokenType    String?
  sandbox      Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([provider])
  @@map("jpb_shipping_integration_config")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("jpb_categories")
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  name          String
  sku           String      @unique
  price         Decimal?    @db.Decimal(12, 2)
  stockQuantity Int         @default(0)
  image         String?
  colorHex      String?
  active        Boolean     @default(true)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  cartItems     CartItem[]

  @@map("jpb_product_variants")
}

model CustomerAddress {
  id                String          @id @default(cuid())
  customerProfileId String
  title             String
  zipCode           String
  street            String
  number            String
  complement        String?
  neighborhood      String
  city              String
  state             String
  isDefault         Boolean         @default(false)
  customerProfile   CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@map("jpb_customer_addresses")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  rating    Int
  comment   String?  @db.Text
  images    String[] @default([])
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("jpb_reviews")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  sessionId String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("jpb_carts")
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int             @default(1)
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("jpb_cart_items")
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  discountType  String // "PERCENTAGE" or "FIXED"
  discountValue Decimal   @db.Decimal(12, 2)
  minOrderValue Decimal?  @db.Decimal(12, 2)
  maxUses       Int?
  usedCount     Int       @default(0)
  startDate     DateTime?
  endDate       DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([active])
  @@map("jpb_coupons")
}

model SupportTicket {
  id            String           @id @default(cuid())
  customerId    String
  customerName  String
  customerEmail String
  subject       String
  description   String           @db.Text
  status        String           @default("OPEN") // OPEN, IN_PROGRESS, CLOSED
  orderId       String?
  images        String[]         @default([])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  customer      User             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages      SupportMessage[]

  @@index([status])
  @@index([customerId])
  @@map("jpb_support_tickets")
}

model SupportMessage {
  id         String   @id @default(cuid())
  ticketId   String
  senderId   String
  senderName String
  senderRole String // CUSTOMER, ADMIN, OPERATOR
  content    String   @db.Text
  images     String[] @default([])
  createdAt  DateTime @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("jpb_support_messages")
}

model Lead {
  id          String   @id @default(cuid())
  email       String
  productId   String?
  productName String?
  status      String   @default("PENDING") // PENDING, NOTIFIED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@map("jpb_leads")
}
